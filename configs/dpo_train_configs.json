{
  "wandb_project": "Andrew-DPO",
  "model": {
    "model_id": "output/SFT/merged_model",
    "torch_dtype": "bfloat16"
  },
  "data": {
    "dpo_data_path": "./output/dpo_training_data.jsonl",
    "max_samples": 5000,
    "eval_split": 0.1
  },
  "training": {
    "output_dir": "./output/terraria_dpo_model",
    "num_train_epochs": 1,
    "per_device_train_batch_size": 1,
    "gradient_accumulation_steps": 16,
    "learning_rate": 5e-6,
    "beta": 0.1,
    "max_length": 2048,
    "warmup_steps": 100,
    "eval_steps": 20,
    "save_steps": 20,
    "save_total_limit": 5,
    "save_strategy": "steps",
    "logging_steps": 10,
    "per_device_eval_batch_size": 1,
    "peft_config": {
      "r": 16,
      "lora_alpha": 32,
      "lora_dropout": 0.05,
      "bias": "none",
      "task_type": "CAUSAL_LM",
      "target_modules": [
        "q_proj",
        "v_proj",
        "k_proj",
        "o_proj",
        "gate_proj",
        "up_proj",
        "down_proj"
      ]
    },
    "loss_type": "sigmoid",
    "logging_first_step": true,
    "remove_unused_columns": true,
    "precompute_ref_log_probs": true
  }
}
